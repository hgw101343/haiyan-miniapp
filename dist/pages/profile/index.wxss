.profile-page{background:#f5f5f5;min-height:100vh}.user-header{-webkit-align-items:center;background:-webkit-linear-gradient(315deg,#ff6b35,#ff9a5c);background:linear-gradient(135deg,#ff6b35,#ff9a5c);display:-webkit-flex;display:-ms-flexbox;display:flex;padding:60rpx 24rpx 40rpx;-ms-flex-align:center;align-items:center;gap:24rpx}.user-header .avatar{border:3rpx solid hsla(0,0%,100%,.5);border-radius:50%;height:100rpx;width:100rpx}.user-header .user-info .nickname{color:#fff;display:block;font-size:34rpx;font-weight:700}.user-header .user-info .phone{color:hsla(0,0%,100%,.8);display:block;font-size:24rpx;margin-top:6rpx}.user-header .user-info .role-badge{background:hsla(0,0%,100%,.3);border-radius:10rpx;color:#fff;display:inline-block;font-size:20rpx;margin-top:8rpx;padding:2rpx 12rpx}.user-header .login-area{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;gap:24rpx}.user-header .login-area .login-avatar{font-size:80rpx}.user-header .login-area .login-info .login-hint{color:hsla(0,0%,100%,.9);display:block;font-size:28rpx;margin-bottom:16rpx}.user-header .login-area .login-info .login-btn{background:hsla(0,0%,100%,.3)!important;border:1rpx solid hsla(0,0%,100%,.5)!important;border-radius:24rpx!important;color:#fff!important;font-size:26rpx!important;line-height:1.4!important;padding:10rpx 28rpx!important}.menu-list{background:#fff;border-radius:12rpx;margin:16rpx;overflow:hidden}.menu-list .menu-item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;border-bottom:1rpx solid #f5f5f5;gap:16rpx;padding:24rpx 20rpx}.menu-list .menu-item:last-child{border-bottom:none}.menu-list .menu-item .menu-icon{font-size:36rpx}.menu-list .menu-item .menu-label{color:#333;-webkit-flex:1;-ms-flex:1;flex:1;font-size:28rpx}.menu-list .menu-item .menu-arrow{color:#ccc;font-size:32rpx}.logout-btn{background:#fff;border-radius:12rpx;color:#f56565;font-size:28rpx;margin:16rpx;padding:24rpx;text-align:center}
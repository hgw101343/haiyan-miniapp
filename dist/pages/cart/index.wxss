.cart-page{background:#f5f5f5;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;height:100vh}.cart-page .cart-list{-webkit-flex:1;-ms-flex:1;flex:1;padding:0 16rpx}.empty-cart{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;gap:24rpx;height:100vh;justify-content:center}.empty-cart .empty-icon{font-size:120rpx}.empty-cart .empty-text{color:#999;font-size:30rpx}.empty-cart .go-shop{background:#ff6b35;border-radius:40rpx;color:#fff;font-size:28rpx;padding:16rpx 48rpx}.cart-item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;background:#fff;border-radius:12rpx;gap:16rpx;margin-top:16rpx;padding:16rpx}.cart-item .item-img{border-radius:8rpx;-webkit-flex-shrink:0;height:80rpx;width:80rpx;-ms-flex-negative:0;flex-shrink:0}.cart-item .item-info{-webkit-flex:1;-ms-flex:1;flex:1}.cart-item .item-info .item-name{color:#222;display:block;font-size:28rpx;font-weight:500}.cart-item .item-info .item-price{color:#ff6b35;display:block;font-size:26rpx;margin-top:8rpx}.cart-item .stepper{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;gap:8rpx}.cart-item .stepper .btn{-webkit-align-items:center;border-radius:50%;display:-webkit-flex;display:-ms-flexbox;display:flex;height:48rpx;width:48rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;font-size:32rpx;font-weight:700;justify-content:center}.cart-item .stepper .btn.minus{background:#f0f0f0;color:#ff6b35}.cart-item .stepper .btn.plus{background:#ff6b35;color:#fff}.cart-item .stepper .num{font-size:28rpx;min-width:32rpx;text-align:center}.remark-section,.table-section{background:#fff;border-radius:12rpx;margin-top:16rpx;padding:16rpx}.remark-section .section-title,.table-section .section-title{color:#333;display:block;font-size:28rpx;font-weight:500;margin-bottom:12rpx}.remark-input{background:#f8f8f8;border-radius:8rpx;color:#333;font-size:26rpx;min-height:80rpx;padding:12rpx;width:100%}.table-input-row{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap;gap:12rpx}.table-input-row .table-chip{background:#f5f5f5;border:2rpx solid transparent;border-radius:20rpx;color:#555;font-size:24rpx;padding:8rpx 20rpx}.table-input-row .table-chip.active{background:#fff0eb;border-color:#ff6b35;color:#ff6b35}.checkout-bar{-webkit-align-items:center;background:#fff;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;border-top:1rpx solid #eee;padding:16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom))}.checkout-bar .total-area{-webkit-flex:1;-ms-flex:1;flex:1}.checkout-bar .total-area .total-label{color:#999;font-size:24rpx}.checkout-bar .total-area .total-price{color:#ff6b35;font-size:36rpx;font-weight:700;margin-left:8rpx}.checkout-bar .checkout-btn{background:#ff6b35;border-radius:48rpx;color:#fff;font-size:30rpx;font-weight:500;padding:16rpx 40rpx}.checkout-bar .checkout-btn.disabled{opacity:.6}
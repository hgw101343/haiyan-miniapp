.detail-page{background:#f5f5f5;min-height:100vh;padding-bottom:120rpx}.loading{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;color:#999;font-size:28rpx;height:100vh;justify-content:center}.status-bar{background:#ff6b35;padding:32rpx 24rpx}.status-bar .status-title{color:#fff;display:block;font-size:36rpx;font-weight:700;margin-bottom:24rpx}.status-bar .progress-steps{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center}.status-bar .progress-steps .step-dot{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-ms-flex-align:center;align-items:center}.status-bar .progress-steps .step-dot::before{background:hsla(0,0%,100%,.4);border-radius:50%;content:"";height:16rpx;margin-bottom:6rpx;width:16rpx}.status-bar .progress-steps .step-dot.done::before{background:#fff}.status-bar .progress-steps .step-dot .dot-label{color:hsla(0,0%,100%,.7);font-size:18rpx;white-space:nowrap}.status-bar .progress-steps .step-dot.done .dot-label{color:#fff}.status-bar .progress-steps .step-line{background:hsla(0,0%,100%,.3);-webkit-flex:1;-ms-flex:1;flex:1;height:2rpx;margin-bottom:20rpx}.status-bar .progress-steps .step-line.done{background:#fff}.info-card,.items-card{background:#fff;border-radius:12rpx;margin:16rpx;padding:20rpx}.info-card .card-title,.items-card .card-title{border-bottom:1rpx solid #f5f5f5;color:#222;display:block;font-size:28rpx;font-weight:500;margin-bottom:16rpx;padding-bottom:12rpx}.info-row{-webkit-align-items:flex-start;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:start;align-items:flex-start;padding:10rpx 0}.info-row .info-label{color:#999;-webkit-flex-shrink:0;font-size:26rpx;width:120rpx;-ms-flex-negative:0;flex-shrink:0}.info-row .info-value{color:#333;-webkit-flex:1;-ms-flex:1;flex:1;font-size:26rpx}.order-item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;border-bottom:1rpx solid #f5f5f5;gap:12rpx;padding:12rpx 0}.order-item:last-of-type{border-bottom:none}.order-item .item-img{border-radius:6rpx;-webkit-flex-shrink:0;height:60rpx;width:60rpx;-ms-flex-negative:0;flex-shrink:0}.order-item .item-info{-webkit-flex:1;-ms-flex:1;flex:1}.order-item .item-info .item-name{color:#333;font-size:26rpx}.order-item .item-info .item-remark{color:#999;font-size:22rpx;margin-top:4rpx}.order-item .item-right{text-align:right}.order-item .item-right .item-qty{color:#999;display:block;font-size:24rpx}.order-item .item-right .item-price{color:#333;display:block;font-size:26rpx;font-weight:500;margin-top:4rpx}.total-row{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;border-top:1rpx solid #f0f0f0;justify-content:space-between;margin-top:8rpx;padding-top:16rpx}.total-row .total-label{color:#333;font-size:28rpx;font-weight:500}.total-row .total-price{color:#ff6b35;font-size:32rpx;font-weight:700}.action-area{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:12rpx;margin:0 16rpx}.action-area .cancel-btn,.action-area .pay-btn{border-radius:48rpx;font-size:30rpx;padding:24rpx;text-align:center;width:100%}.action-area .pay-btn{background:#ff6b35;color:#fff;font-weight:500}.action-area .pay-btn.disabled{opacity:.6}.action-area .cancel-btn{background:#fff;border:1rpx solid #ddd;color:#999}
.order-page{background:#f5f5f5;min-height:100vh}.order-page .status-tabs{background:#fff;border-bottom:1rpx solid #eee;padding:0 12rpx;white-space:nowrap}.order-page .status-tabs .tab{color:#666;display:inline-block;font-size:26rpx;padding:20rpx 24rpx}.order-page .status-tabs .tab.active{border-bottom:4rpx solid #ff6b35;color:#ff6b35;font-weight:500}.order-page .order-list{padding:16rpx}.order-page .empty,.order-page .loading{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;color:#999;font-size:26rpx;gap:16rpx;justify-content:center;padding:80rpx 0}.order-page .empty .empty-icon,.order-page .loading .empty-icon{font-size:80rpx}.order-card{background:#fff;border-radius:12rpx;margin-bottom:16rpx;padding:16rpx 20rpx}.order-card .order-header{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:center;justify-content:space-between;-ms-flex-align:center;align-items:center;border-bottom:1rpx solid #f5f5f5;margin-bottom:12rpx;padding-bottom:12rpx}.order-card .order-header .order-no{color:#999;font-size:24rpx}.order-card .order-header .order-status{font-size:26rpx;font-weight:500}.order-card .order-items{margin-bottom:12rpx}.order-card .order-items .item-more,.order-card .order-items .item-name{color:#333;display:block;font-size:26rpx;margin-bottom:4rpx}.order-card .order-items .item-more{color:#999}.order-card .order-footer{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:center;justify-content:space-between;-ms-flex-align:center;align-items:center}.order-card .order-footer .order-time{color:#999;font-size:22rpx}.order-card .order-footer .order-total{color:#ff6b35;font-size:30rpx;font-weight:700}